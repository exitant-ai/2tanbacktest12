<!DOCTYPE html><html lang="ko"><head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title>EXITANT 터틀 — 무한 복리 백테스트 설명서</title>
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#05090a;--panel:#0b140e;--line:#1c3022;--g:#2ee884;--g2:#39e06a;--red:#f0565b;--cyan:#37c6e0;--yel:#ffd23f;--tx:#e8f3ec;--mut:#9db1a6;--faint:#5a6f63}
*{margin:0;padding:0;box-sizing:border-box}html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--tx);font-family:'Space Grotesk','Apple SD Gothic Neo','Malgun Gothic',sans-serif;-webkit-font-smoothing:antialiased;line-height:1.5}
.mono{font-family:'JetBrains Mono','Apple SD Gothic Neo',monospace}
.g{color:var(--g)}.g2{color:var(--g2)}.r{color:var(--red)}.cy{color:var(--cyan)}.y{color:var(--yel)}.mut{color:var(--mut)}
b,strong{color:#fff;font-weight:700}
/* nav */
.top{position:fixed;top:0;left:0;right:0;z-index:30;display:flex;justify-content:space-between;align-items:center;
  padding:14px 26px;background:linear-gradient(#05090af2,#05090a00);font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:1px;backdrop-filter:blur(2px)}
.top .brand b{color:var(--g)}
.top nav a{color:var(--mut);text-decoration:none;margin-left:16px;font-size:11.5px}
.top nav a:hover{color:var(--g)}
@media(max-width:780px){.top nav{display:none}}
/* sections */
section{padding:88px 26px;position:relative;border-top:1px solid #0d1812}
section:first-of-type{border-top:0}
.glow::before{content:"";position:absolute;inset:0 0 auto 0;height:360px;pointer-events:none;
  background:radial-gradient(640px 320px at 24% 0,rgba(46,232,132,.13),transparent 70%)}
.wrap{max-width:1040px;margin:0 auto;position:relative}
.eyebrow{font-family:'JetBrains Mono',monospace;font-size:11.5px;letter-spacing:4px;color:var(--g);text-transform:uppercase;margin-bottom:14px;font-weight:700}
h1{font-size:clamp(34px,6vw,62px);font-weight:700;letter-spacing:-1.5px;line-height:1.06}
h2{font-size:clamp(26px,4.4vw,44px);font-weight:700;letter-spacing:-1px;line-height:1.1;margin-bottom:16px}
.lead{font-size:clamp(15px,1.9vw,18px);color:#c4d6cb;line-height:1.7;max-width:66ch;margin-bottom:14px}
.lead b{color:#fff}
.chartcard{margin:22px 0 12px;border:1px solid var(--line);border-radius:18px;background:var(--panel);padding:14px;box-shadow:0 24px 70px -34px rgba(0,0,0,.85)}
.chartcard svg{display:block;width:100%;height:auto}
.cap{font-family:'JetBrains Mono',monospace;font-size:12.5px;color:var(--mut);text-align:center;margin-top:10px;line-height:1.55}
.cap b{color:#cfe7da}
.kvs{display:flex;gap:14px;flex-wrap:wrap;margin-top:8px}
.kv{flex:1;min-width:165px;border:1px solid var(--line);border-radius:14px;background:var(--panel);padding:13px 16px}
.kv .t{font-size:11px;color:var(--mut);font-family:'JetBrains Mono',monospace;margin-bottom:5px;letter-spacing:1px}
.kv .v{font-size:15px;line-height:1.5}.kv .v b{color:#fff}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:8px 0}
@media(max-width:680px){.grid2{grid-template-columns:1fr}}
.card{border:1px solid var(--line);border-radius:16px;background:var(--panel);padding:18px 20px}
.card h3{font-size:17px;color:#fff;margin-bottom:7px}
.card p{font-size:13.5px;color:#c4d6cb;line-height:1.6}
.formula{border:1px solid #244536;border-radius:14px;background:#08130d;padding:16px 18px;margin:10px 0;
  font-family:'JetBrains Mono',monospace;font-size:clamp(14px,2vw,17px);color:#cfe9f2;text-align:center;line-height:1.8}
.formula b{color:var(--yel)}.formula .sub{display:block;font-size:13px;color:var(--mut);margin-top:4px}
.exits{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin:8px 0}
@media(max-width:680px){.exits{grid-template-columns:1fr}}
.exit{border:1px solid var(--line);border-radius:16px;background:var(--panel);padding:18px;text-align:center}
.exit .n{font-size:26px;font-weight:800;margin-bottom:6px}
.exit .h{font-size:15px;color:#fff;font-weight:700;margin-bottom:6px}
.exit .d{font-size:12.5px;color:var(--mut);line-height:1.5}
table{width:100%;border-collapse:collapse;margin:16px 0;font-size:13.5px}
th,td{border:1px solid var(--line);padding:10px 13px;text-align:left}
th{background:#0c1812;color:#cfe7da}
.callout{border:1px solid #244536;border-left:3px solid var(--g);border-radius:0 12px 12px 0;background:#08130d;padding:14px 18px;margin:12px 0;font-size:14px;line-height:1.65}
.callout.warn{border-left-color:var(--red)}
.minis .mlab{display:flex;justify-content:space-between;align-items:baseline;margin:4px 4px 16px}
.minis .mlab .nm{font-family:'JetBrains Mono',monospace;font-size:14px;font-weight:700;color:var(--g)}
.minis .mlab .rt{font-family:'JetBrains Mono',monospace;font-size:17px;font-weight:800;color:var(--yel)}
.minis .mlab .sub{font-size:12px;color:var(--mut)}
.big{font-size:clamp(20px,3vw,32px);font-weight:700;color:#fff;line-height:1.3;margin:10px 0 18px}
.cta{display:flex;gap:14px;flex-wrap:wrap;margin-top:24px}
.btn{font-family:'JetBrains Mono',monospace;font-size:14px;font-weight:700;text-decoration:none;padding:15px 26px;border-radius:12px;transition:.15s}
.btn.p{background:var(--g);color:#04130a}.btn.p:hover{box-shadow:0 0 0 4px rgba(46,232,132,.2)}
.btn.s{border:1px solid var(--line);color:var(--tx)}.btn.s:hover{border-color:var(--g);color:var(--g)}
.disc{font-size:12.5px;color:var(--faint);line-height:1.65;margin-top:22px;border-top:1px solid var(--line);padding-top:16px}
.settings{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-top:10px}
@media(max-width:880px){.settings{grid-template-columns:1fr 1fr}}
@media(max-width:560px){.settings{grid-template-columns:1fr}}
.st{border:1px solid var(--line);border-radius:14px;background:var(--panel);padding:15px 16px}
.st .h{display:flex;align-items:baseline;gap:8px;margin-bottom:6px}
.st .h .nm{font-size:14.5px;font-weight:700;color:#fff}
.st .h .b{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:#04130a;background:var(--g);border-radius:6px;padding:2px 8px;font-weight:800}
.st p{font-size:12.5px;color:#c4d6cb;line-height:1.55}
.st .rng{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--mut);margin-top:6px}
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding-top:120px}
.tag{display:inline-flex;gap:8px;align-items:center;font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--mut);border:1px solid var(--line);border-radius:30px;padding:6px 14px;margin-bottom:22px;width:max-content}
.tag i{width:7px;height:7px;border-radius:50%;background:var(--g);display:inline-block}
.foot{max-width:1040px;margin:0 auto;padding:40px 26px 60px;color:var(--faint);font-family:'JetBrains Mono',monospace;font-size:11px;border-top:1px solid var(--line)}
</style></head><body>

